# Public site URL - used for OG tags, sitemap, canonical URLs.
# Update this once the final production domain is obtained.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# GitHub API token (optional, read-only). Used at build time to fetch repo
# metadata (stars, last commit) for project cards. Without it, badges
# fall back to static values.
GITHUB_TOKEN=

# Plausible analytics (optional). Set the domain you registered with Plausible.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Contact email delivery via Resend.
RESEND_API_KEY=
CONTACT_TO_EMAIL=shahriarirad.reza@mayo.edu
# CONTACT_FROM_EMAIL must be a verified sender or verified domain in Resend.
CONTACT_FROM_EMAIL=
