# Public site URL - used for OG tags, sitemap, canonical URLs.
# Keep localhost locally. In Vercel, either set this to the production URL
# or enable Vercel system environment variables so the app can use
# VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# GitHub API token (optional, read-only). Used at build time to fetch repo
# metadata (stars, last commit) for project cards. Without it, badges
# fall back to static values.
GITHUB_TOKEN=

# Plausible analytics (optional). Set the domain you registered with Plausible.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Contact uses mailto: links only — no email service or API key needed.
